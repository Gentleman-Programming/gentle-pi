{
  "name": "gentle-pi",
  "version": "0.1.18",
  "description": "Turn Pi into el Gentleman: a senior-architect development harness with SDD/OpenSpec, subagents, strict TDD evidence, review guardrails, and skill discovery.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "gentle-pi",
    "gentle-ai",
    "sdd",
    "openspec",
    "subagents",
    "tdd",
    "code-review",
    "ai-coding-agent",
    "agent-harness"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gentleman-Programming/gentle-pi.git"
  },
  "files": [
    "assets/",
    "extensions/",
    "prompts/",
    "skills/",
    "scripts/",
    "README.md"
  ],
  "scripts": {
    "prepack": "node scripts/verify-package-files.mjs",
    "prepublishOnly": "node scripts/verify-package-files.mjs"
  },
  "pi": {
    "image": "https://cdn.jsdelivr.net/npm/gentle-pi/assets/gentle-logo-only.png",
    "extensions": [
      "./extensions"
    ],
    "prompts": [
      "./prompts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-tui": "*"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  }
}
